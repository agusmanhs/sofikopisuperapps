# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# ── iOS (bare RN: commit native, abaikan build & Pods) ──
ios/build/
ios/Pods/
ios/*.xcworkspace/xcuserdata/
ios/*.xcodeproj/xcuserdata/
ios/.xcode.env.local
ios/DerivedData/

# ── Android (bare RN: commit native, abaikan build & gradle) ──
android/build/
android/app/build/
android/app/.cxx/
android/.gradle/
android/.idea/
android/local.properties
android/.kotlin/
*.apk
*.aab
*.keystore
!debug.keystore
